DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=astrocode

# JWT used to sign auth tokens
JWT_SECRET=dev-secret

# PayPal credentials (recommended: sandbox for local development)
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox

# URL used for return/cancel from checkout (must load account page to auto-confirm)
PAYPAL_FRONTEND_URL=http://localhost:4200/account

# Optional webhook settings (required only if using PayPal webhooks locally)
# Use a public URL via ngrok/localtunnel for PAYPAL_NOTIFICATION_URL
PAYPAL_NOTIFICATION_URL=
PAYPAL_WEBHOOK_ID=

MP_FRONTEND_URL=http://localhost:4200/account
